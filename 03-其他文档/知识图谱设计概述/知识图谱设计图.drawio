        <mxCell id="b2y-Js0biUwOLFObtFVq-30" edge="1" parent="1" source="b2y-Js0biUwOLFObtFVq-21" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="b2y-Js0biUwOLFObtFVq-28" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="400" y="220" as="sourcePoint" />
            <mxPoint x="420" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="b2y-Js0biUwOLFObtFVq-31" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="元数据口径之间不建立链接，链接通过元数据口径-元数据节点-元数据口径通路实现&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;元数据口径连接的所有元数据视为同一种数据&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;思考：18位证件号经常和15位证件号混着存在表里，它们应该是同一个口径吗？&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;目前我认为元数据口径相同=两个表可以join on it&lt;/div&gt;" vertex="1">
          <mxGeometry height="215" width="160" x="490" y="-45" as="geometry" />
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-2" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="组合口径" vertex="1">
          <mxGeometry height="60" width="60" x="290" y="210" as="geometry" />
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-3" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="0bbYdX_QtQtvJLRfY4Wd-2" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="210" y="250" as="sourcePoint" />
            <mxPoint x="540" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="一系列元数据口径的组合,包含必要元素,和多级推荐元素&lt;div&gt;例如:代发交易流水必须要有代发交易日期,代发交易金额,户口号,一级推荐代发交易流水号,代发交易套号&lt;/div&gt;&lt;div&gt;组合口径完全由元数据口径组合而成,只要组成的元数据口径不同,组合口径就不同;&lt;/div&gt;&lt;div&gt;组合口径尽量由人为配置;&lt;/div&gt;&lt;div&gt;有时组合口径也可以包含统计字段&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="390" x="375" y="200" as="geometry" />
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="包含大量知识的语义子图,&lt;div&gt;场景节点是这个语义子图的摘要&lt;/div&gt;&lt;div&gt;(尽管我们还没有制作出知识节点)&lt;br&gt;&lt;div&gt;拥有较高冗余度&lt;div&gt;只连接元数据口径与组合口径,&lt;/div&gt;&lt;div&gt;精心设计的语义模块&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="210" x="370" y="320" as="geometry" />
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-6" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="词元" vertex="1">
          <mxGeometry height="60" width="60" x="290" y="460" as="geometry" />
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-7" edge="1" parent="1" source="b2y-Js0biUwOLFObtFVq-3" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0;entryDx=0;entryDy=0;exitX=0.75;exitY=1;exitDx=0;exitDy=0;" target="0bbYdX_QtQtvJLRfY4Wd-6" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="220" y="260" as="sourcePoint" />
