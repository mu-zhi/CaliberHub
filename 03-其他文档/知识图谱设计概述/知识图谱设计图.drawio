    <mxGraphModel dx="794" dy="457" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="IytmYhnAS70KpuxPYPdc-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="双向广度优先搜索算法" vertex="1">
          <mxGeometry height="60" width="120" x="414" y="130" as="geometry" />
        </mxCell>
        <mxCell id="IytmYhnAS70KpuxPYPdc-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="合法路径约束" vertex="1">
          <mxGeometry height="60" width="120" x="414" y="20" as="geometry" />
        </mxCell>
        <mxCell id="IytmYhnAS70KpuxPYPdc-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;span style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif; text-align: left;&quot;&gt;评分函数=边权重-路径长度惩罚+语义相似度奖励&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="296" x="326" y="240" as="geometry" />
        </mxCell>
        <mxCell id="2guHzMZqwZHXOGV6MI_5-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;26,0,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;26,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;基础得分&lt;/b&gt; = 置信度 *&amp;nbsp;语义相似度^2。&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;26,1,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;26,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;动态加权&lt;/b&gt; = 基础得分 *&lt;span class=&quot;math-inline&quot; data-math=&quot;\times (1 + \text{w} \cdot \text{Normalized\_Popularity})&quot; data-index-in-node=&quot;12&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&amp;nbsp;(1 + log(热度))&lt;/span&gt;。&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="80" width="480" x="220" y="350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
