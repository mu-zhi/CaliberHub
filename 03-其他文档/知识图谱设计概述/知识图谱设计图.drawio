          </mxGeometry>
        </mxCell>
        <mxCell id="0bbYdX_QtQtvJLRfY4Wd-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="高度组织的知识云,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;与场景节点协同进化,让知识图谱取得自组织逻辑性能&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;通向&lt;/span&gt;&lt;span style=&quot;background-color: rgb(40, 42, 44); color: rgb(227, 227, 227); font-family: &amp;quot;Google Sans Flex&amp;quot;, &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; font-variant-ligatures: none; text-align: start;&quot;&gt;全量本体推理&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;;&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;不参与元数据查询;&lt;/div&gt;&lt;/div&gt;" vertex="1">
