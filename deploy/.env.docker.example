# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=caliber
MYSQL_USER=caliber
MYSQL_PASSWORD=caliber

# ---------- Security ----------
CALIBER_SECURITY_ENABLED=true
CALIBER_REQUIRE_WRITE_AUTH=true
CALIBER_JWT_SECRET=change_me_jwt_secret_at_least_32_chars

CALIBER_ADMIN_PASSWORD=change_me_admin_password
CALIBER_SUPPORT_PASSWORD=change_me_support_password
CALIBER_EXPERT_PASSWORD=change_me_expert_password
CALIBER_GOVERNANCE_PASSWORD=change_me_governance_password
CALIBER_FRONTLINE_PASSWORD=change_me_frontline_password
CALIBER_COMPLIANCE_PASSWORD=change_me_compliance_password

# ---------- LLM ----------
CALIBER_LLM_ENDPOINT=https://coding.dashscope.aliyuncs.com/v1/chat/completions
CALIBER_LLM_API_KEY=
CALIBER_LLM_SECRET_KEY=change_me_llm_secret_key

# ---------- Redis (optional) ----------
CALIBER_CACHE_REDIS_ENABLED=false
CALIBER_CACHE_TTL_SECONDS=300

# ---------- Neo4j (optional) ----------
CALIBER_GRAPH_PROJECTION_ENABLED=false
CALIBER_GRAPH_READ_ENABLED=false
CALIBER_GRAPH_VECTOR_ENABLED=false
CALIBER_GRAPH_REBUILD_ENABLED=true
CALIBER_NEO4J_USERNAME=neo4j
CALIBER_NEO4J_PASSWORD=change_me_neo4j_password
NEO4J_AUTH=neo4j/change_me_neo4j_password

# ---------- App Info ----------
DD_APP_VERSION=0.1.0
DD_APP_BUILD_TIME=docker
DD_FRONTEND_DIST_VERSION=docker
